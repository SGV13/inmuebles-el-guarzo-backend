# Inmuebles El Guarzo — environment variables
#
# Production source of truth: Doppler (https://dashboard.doppler.com)
# Project: inmuebles-el-guarzo · Config: dev/stg/prd
#
# This file exists ONLY to document which variables the app expects.
# Do NOT copy this to .env — the app reads from Doppler via `doppler run --`.
# To run locally: ensure `doppler setup` was run, then `pnpm start:dev`.

# Entorno de ejecucion. Valores validos: development | test | production
NODE_ENV=development

# Conexion a Postgres (Neon). Obtener desde: Neon Console > Project > Connection string
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# URL base del proyecto de Supabase. Obtener desde: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Anon key publica (segura para exponer al frontend). Misma fuente que SUPABASE_URL.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SECRETA — privilegios totales sobre el proyecto Supabase).
# Misma fuente que SUPABASE_URL. NUNCA exponer al frontend ni a logs.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWKS publico de Supabase para verificar firmas JWT.
# Formato estandar: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co/auth/v1/.well-known/jwks.json

# =============================================================================
# Variables TEMPORALES para el script seed:admin
# Agregar solo cuando vayas a correr: pnpm seed:admin
# BORRAR del .env inmediatamente despues de ejecutar el seed.
# =============================================================================

# SEED_ADMIN_EMAIL=admin@tudominio.com
# SEED_ADMIN_FULL_NAME=Nombre Apellido
# SEED_ADMIN_PHONE=3001234567
